@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject ThemeService Theme
@inject AppState AppState
@inject IJSRuntime JS

<AppStyles />
<MudThemeProvider Theme="@Theme.Theme" IsDarkMode="@Theme.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<div class="app-shell">
    <main class="app-main">
        @Body
    </main>
</div>
<FloatingNav />
<ToastHost />

@code {
    protected override async Task OnInitializedAsync()
    {
        await Theme.InitializeAsync();
        await AppState.InitializeAsync();
        Theme.OnChanged += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            await JS.InvokeVoidAsync("tgTodoTelegram.enableGestures");
            await JS.InvokeVoidAsync("tgTodoUi.initHorizontalScroll");
        }
        catch
        {
            // dev browser
        }
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public async ValueTask DisposeAsync()
    {
        Theme.OnChanged -= OnThemeChanged;
        await Theme.DisposeAsync();
    }
}
